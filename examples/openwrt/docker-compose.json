{
    "version": "3.9",
    "services": {
        "openwrt": {
            "container_name": "openwrt",
            "image": "openwrt:latest",
            "privileged": true,
            "command": "/sbin/init && service network restart && echo -e 'root\nroot' | passwd && service firewall restart",
            "volumes": [
                "./network:/etc/config/network",
                "./dropbear:/etc/config/dropbear",
                "./firewall:/etc/config/firewall",
                "./profile:/etc/profile",
                "./shinit:/etc/shinit"
            ],
            "ports": [
                "2401:22"
            ],
            "hostname": "openwrt",
            "environment": {
                "term": "DUMB"
            }
        },
        "router": {
            "container_name": "router",
            "image": "raikou/router",
            "build": {
                "context": "https://github.com/lgirdk/raikou-net.git#main:components/router",
                "tags": [
                    "router:frr_9.0"
                ]
            },
            "ports": [
                "4000:22"
            ],
            "environment": {
                "DHCP_RELAY": "172.25.1.20,2001:dead:beef:2::20",
                "CPE_MGMT": "vl_eth0,10.1.1.1/24,2001:dead:cafe:1::1/64",
                "CPE_DATA": "vl_eth1,10.1.2.1/24,2001:dead:cafe:2::1/64",
                "CPE_VOICE": "vl_eth2,10.1.3.1/24,2001:dead:cafe:3::1/64"
            },
            "privileged": true,
            "hostname": "router",
            "depends_on": [
                "ssh_service"
            ]
        },
        "wan": {
            "container_name": "wan",
            "image": "raikou/wan",
            "build": {
                "context": "https://github.com/lgirdk/raikou-net.git#main:components/wan",
                "tags": [
                    "wan:lwds_lite_1.0"
                ]
            },
            "ports": [
                "4001:22"
            ],
            "environment": {
                "LEGACY": "no"
            },
            "privileged": true,
            "hostname": "wan",
            "depends_on": [
                "ssh_service"
            ]
        },
        "lan1": {
            "container_name": "lan1",
            "image": "raikou/lan",
            "build": {
                "context": "https://github.com/lgirdk/raikou-net.git#main:components/lan",
                "tags": [
                    "lan:container_utils_1.1.1"
                ]
            },
            "ports": [
                "4002:22"
            ],
            "environment": {
                "LEGACY": "no"
            },
            "privileged": true,
            "hostname": "lan1",
            "depends_on": [
                "ssh_service"
            ]
        },
        "lan2": {
            "container_name": "lan2",
            "image": "raikou/lan",
            "build": {
                "context": "https://github.com/lgirdk/raikou-net.git#main:components/lan",
                "tags": [
                    "lan:container_utils_1.1.1"
                ]
            },
            "ports": [
                "4003:22"
            ],
            "environment": {
                "LEGACY": "no"
            },
            "privileged": true,
            "hostname": "lan2",
            "depends_on": [
                "ssh_service"
            ]
        },
        "dhcp": {
            "container_name": "dhcp",
            "image": "raikou/dhcp",
            "build": {
                "context": "https://github.com/lgirdk/raikou-net.git#main:components/dhcp",
                "tags": [
                    "dhcp:kea_dhcp_2.5.2"
                ]
            },
            "ports": [
                "4004:22"
            ],
            "environment": {
                "LEGACY": "no"
            },
            "privileged": true,
            "hostname": "dhcp",
            "depends_on": [
                "ssh_service"
            ]
        },
        "raikou-net": {
            "image": "raikou/raikou-net",
            "build": {
                "context": "https://github.com/lgirdk/raikou-net.git#main",
                "tags": [
                    "raikou-net:alpine3.18-dind-ovs_2.17"
                ]
            },
            "volumes": [
                "/lib/modules:/lib/modules",
                "/var/run/docker.sock:/var/run/docker.sock",
                "./config.json:/root/config.json"
            ],
            "privileged": true,
            "pid": "host",
            "network_mode": "host",
            "hostname": "orchestrator",
            "depends_on": [
                "openwrt",
                "router",
                "wan",
                "lan1",
                "lan2",
                "dhcp"
            ]
        },
        "ssh_service": {
            "image": "raikou/ssh",
            "build": {
                "context": "https://github.com/lgirdk/raikou-net.git#main:components/ssh",
                "tags": [
                    "ssh:1.9.2p1"
                ]
            }
        }
    },
    "networks": {
        "default": {
            "ipam": {
                "config": [
                    {
                        "subnet": "192.168.55.0/24",
                        "gateway": "192.168.55.1"
                    }
                ]
            }
        }
    }
}